# Configuration Supabase - Ferme Circulaire
# Copiez ce fichier vers .env.local et remplissez les valeurs

NEXT_PUBLIC_SUPABASE_URL=votre_url_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_clé_anon

# Optionnel: Pour l'authentification
SUPABASE_SERVICE_ROLE_KEY=votre_clé_service (uniquement pour les scripts backend)